# Ignore everything by default
*

# tb_src/ is local only (tablebases source, not tracked)
tb_src/

# Except engine/, gui/, logos/, run/*.py, run/*.txt, learn/, and this file
!engine/
!engine/**
!gui/
!gui/**
!logos/
!logos/**
!.gitignore
!README.md
!CLAUDE.md
!run/
run/*
!run/*.py
!run/*.txt
!learn/
learn/*
!learn/*.py
!learn/*.pl
!learn/*.txt
!learn/training_openings.epd

# Within engine/src/, ignore OS/editor artifacts and binary/backup files
engine/src/.DS_Store
engine/src/**/.DS_Store
engine/src/*~
engine/src/**/*~
engine/src/#*#
engine/src/**/#*#
engine/src/*.cpp_*
engine/src/*.h_save
engine/src/main_bk.dat
engine/src/debug.txt
engine/scripts/__pycache__

# Within gui/, ignore Flutter build artifacts and IDE files
gui/build/
gui/.dart_tool/
gui/.idea/
gui/.swiftpm/
gui/*.iml
gui/.packages
gui/.flutter-plugins
gui/.flutter-plugins-dependencies
gui/assets/engines/
