# Ignore everything by default
*

# tb_src/ is local only (tablebases source, not tracked)
tb_src/

# Except src/, docs/, scripts/, logos/, run/*.py, run/*.txt, learn/, and this file
!logos/
!logos/**
!src/
!src/**
!docs/
!docs/**
!scripts/
!scripts/**
!.gitignore
!README.md
!CLAUDE.md
!run/
run/*
!run/*.py
!run/*.txt
!learn/
learn/*
!learn/*.py
!learn/*.pl
!learn/*.txt

# Within src/, ignore OS/editor artifacts and binary/backup files
src/.DS_Store
src/**/.DS_Store
src/*~
src/**/*~
src/#*#
src/**/#*#
src/*.cpp_*
src/*.h_save
src/main_bk.dat
src/debug.txt
scripts/__pycache__