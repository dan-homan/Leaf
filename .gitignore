# Ignore everything by default
*

# Except src/, docs/, run/*.py, run/*.txt, learn/, and this file
!src/
!src/**
!docs/
!docs/**
!.gitignore
!README.md
!run/
run/*
!run/*.py
!run/*.txt
!learn/
learn/*
!learn/*.py
!learn/*.pl
!learn/*.txt

# Within src/, ignore OS/editor artifacts and binary/backup files
src/.DS_Store
src/**/.DS_Store
src/*~
src/**/*~
src/#*#
src/**/#*#
src/*.cpp_*
src/*.h_save
src/main_bk.dat
src/debug.txt
