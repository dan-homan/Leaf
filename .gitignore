# Ignore everything by default
*

# tb_src/ is local only (tablebases source, not tracked)
tb_src/

# Except engine/, gui/, logos/, scripts/, and root files
!engine/
!engine/**
!gui/
!gui/**
!logos/
!logos/**
!scripts/
scripts/*
!scripts/build_release.sh
!.gitignore
!README.md
!CLAUDE.md

# Within engine/run/, only track scripts and config (not binaries or data files)
engine/run/*
!engine/run/*.py
!engine/run/*.pl
!engine/run/*.txt

# Within engine/learn/, only track scripts and config
engine/learn/*
!engine/learn/*.py
!engine/learn/*.pl
!engine/learn/*.txt
!engine/learn/training_openings.epd

# Within engine/src/, ignore OS/editor artifacts and binary/backup files
engine/src/.DS_Store
engine/src/**/.DS_Store
engine/src/*~
engine/src/**/*~
engine/src/#*#
engine/src/**/#*#
engine/src/*.cpp_*
engine/src/*.h_save
engine/src/main_bk.dat
engine/src/debug.txt
engine/scripts/__pycache__

# Within gui/, ignore Flutter build artifacts and IDE files
gui/build/
gui/.dart_tool/
gui/.idea/
gui/.swiftpm/
gui/*.iml
gui/.packages
gui/.flutter-plugins
gui/.flutter-plugins-dependencies
gui/assets/engines/
